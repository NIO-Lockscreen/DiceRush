{
  "functions": {
    "api/mp3-list.js": {
      "includeFiles": "mp3/**"
    },
    "api/leaderboard.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/mp3/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}